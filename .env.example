# Proof of Inevitability — environment template
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file. It is gitignored.

# Your Interledger test wallet address (get one at https://wallet.interledger-test.dev)
WALLET_ADDRESS=https://ilp.interledger-test.dev/your-wallet-id

# The Key ID associated with your wallet's signing key pair
KEY_ID=your-key-id-uuid

# Path to your private key file (the file itself is gitignored)
PRIVATE_KEY_PATH=./private.key

# OpenAI API key (get one at https://platform.openai.com)
OPENAI_API_KEY=sk-your-openai-key

# Server port (default 3000)
PORT=3000
